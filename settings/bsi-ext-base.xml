<?xml version="1.0" encoding="utf-8"?>
<!--
    Общая секция <bsi-ext> для модулей. Подключается через
    <include src="bsi-ext-base.xml"/> внутри <resources>.
    Каждая <record> описывает строку расширенной вкладки InfoDialog:
      <name>           - objectName лейбла со значением
      <desc>           - текст лейбла-подписи слева
      <representation> - символическое имя форматирования значения; см.
                         enum class ViewTypes в библиотеке avm-widgets
                         и InfoDialog::fillBsiExt.
-->
<fragment>
    <bsi-ext>
        <record>
            <name>namepo</name>
            <desc>Наименование программы:</desc>
            <representation>String</representation>
            <offset>0</offset>
        </record>
        <record>
            <name>verloader</name>
            <desc>Версия Loader:</desc>
            <representation>Version</representation>
            <offset>1</offset>
        </record>
    </bsi-ext>
</fragment>
